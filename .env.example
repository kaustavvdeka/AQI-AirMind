# Shared secrets for the whole AirMind AI monorepo (ai/ and backend/ both
# read this single file). Copy to .env at the project root and fill in
# your own values — never commit the real .env.

# --- 1. Air Quality & Weather Data APIs ---
# OpenAQ API Key (Get from https://openaq.org)
OPENAQ_API_KEY=your_openaq_key_here

# OpenWeather API Key (Get from https://openweathermap.org/api)
OPENWEATHER_API_KEY=your_openweather_key_here

# --- 2. Satellite Intelligence APIs ---
# Google Earth Engine Cloud Project ID (Console: https://console.cloud.google.com)
GEE_PROJECT_ID=your-gee-project-id

# NASA FIRMS Thermal Anomaly / Fire Map Key (Get from https://firms.modaps.eosdis.nasa.gov/api/map_key)
FIRMS_MAP_KEY=your_firms_map_key_here

# --- 3. Traffic Intelligence APIs ---
# TomTom Traffic & Maps API Key (Get from https://developer.tomtom.com)
TOMTOM_API_KEY=your_tomtom_api_key_here

# HERE Maps Traffic API Key (Optional alternative)
HERE_API_KEY=your_here_api_key_here

# --- 4. AI & LLM Recommendation APIs ---
# Google Gemini API Key for AI Enforcement & Health Guidance (Get from https://aistudio.google.com)
GEMINI_API_KEY=your_gemini_key_here

# --- 5. Database & Cache Services ---
# MongoDB Atlas Connection URI
MONGODB_URI=mongodb://127.0.0.1:27017/airmind

# Redis URI (Optional: for high-performance caching of raster & grid predictions)
REDIS_URL=redis://localhost:6379

# --- 6. Backend & Authentication ---
JWT_SECRET=airmind_secret_jwt_token_2026_key_hackathon
JWT_EXPIRES_IN=7d
PORT=5000
FRONTEND_ORIGIN=http://localhost:5173
AI_SERVICE_URL=http://localhost:8000

# --- 7. Default Location & Multi-City Settings ---
DEFAULT_LAT=26.1445
DEFAULT_LON=91.7362
DEFAULT_CITY=Guwahati

# ML Settings
MODEL_TYPE=auto
LIGHTGBM_ENABLED=true
CATBOOST_ENABLED=true

