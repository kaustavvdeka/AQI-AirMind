# Shared secrets for the whole AirMind AI monorepo (ai/ and backend/ both
# read this single file). Copy to .env at the project root and fill in
# your own values — never commit the real .env.

# --- OpenAQ ---
OPENAQ_API_KEY=your_openaq_key_here

# --- OpenWeather ---
OPENWEATHER_API_KEY=your_openweather_key_here

# --- Google Earth Engine ---
# Register a project at https://console.cloud.google.com (enable the Earth
# Engine API), then run `earthengine authenticate` once locally.
GEE_PROJECT_ID=your-gee-project-id

# --- Gemini (recommendation engine) ---
# Optional: without this, recommendations fall back to rule-based logic.
GEMINI_API_KEY=your_gemini_key_here

# --- MongoDB Atlas ---
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/airmind

# --- Backend ---
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d
PORT=5000
FRONTEND_ORIGIN=http://localhost:5173
AI_SERVICE_URL=http://localhost:8000

# --- Default demo location (Guwahati) ---
DEFAULT_LAT=26.1445
DEFAULT_LON=91.7362
DEFAULT_CITY=Guwahati
